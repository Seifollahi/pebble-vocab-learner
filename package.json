{
  "name": "pebble_vocab_learner",
  "author": "Mo Seif",
  "version": "2.2.0",
  "description": "A minimalist, highly effective vocabulary learning application built natively for the Pebble ecosystem.",
  "keywords": [
    "pebble-app"
  ],
  "license": "MIT",
  "dependencies": {},
  "pebble": {
    "displayName": "Vocab Learner",
    "uuid": "445cd633-85d3-49ff-a7f3-b31cb61ec47f",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery"
    ],
    "watchapp": {
      "watchface": false
    },
    "menuIcon": "IMAGE_MENU_ICON",
    "capabilities": [
      "configurable",
      "timeline"
    ],
    "messageKeys": [
      "NOTIFICATIONS_ENABLED",
      "NOTIFICATIONS_FREQUENCY",
      "VIBRATION_ENABLED",
      "DIFF_BASIC",
      "DIFF_INTERMEDIATE",
      "DIFF_ADVANCED",
      "RESET_PROGRESS",
      "STAT_LEARNED",
      "STAT_REVIEWED",
      "STAT_GRADUATED",
      "STAT_TOTAL"
    ],
    "resources": {
      "media": [
        {
          "type": "raw",
          "name": "VOCAB_DB",
          "file": "data/vocab_db.bin"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_MENU_ICON",
          "file": "images/menu_icon.png",
          "menuIcon": true
        }
      ],
      "publishedMedia": [
        {
          "name": "APP_GLANCE_ICON",
          "glance": "IMAGE_MENU_ICON",
          "timeline": {
            "tiny": "IMAGE_MENU_ICON"
          },
          "id": 1
        }
      ]
    }
  }
}